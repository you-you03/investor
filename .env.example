# Slack Incoming Webhook URL (REQUIRED)
# Create at: https://api.slack.com/apps -> Incoming Webhooks
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/...

# ANTHROPIC_API_KEY は不要 — Claude Code セッション自体がエージェントとして動作するため。
# Python スクリプトは Anthropic SDK を呼ばない。CLAUDE.md の「Critical Design Rule」を参照。

# Perplexity Sonar API (Optional: web search enhancement)
# https://www.perplexity.ai/settings/api
PERPLEXITY_API_KEY=pplx-...

# xAI (Grok) API key (Optional: X/Twitter sentiment via x_search)
# Create at: https://console.x.ai
XAI_API_KEY=xai-...

# Agent behavior tuning
RESEARCH_MAX_TICKERS=10
RESEARCH_TOP_CANDIDATES=5
MONITOR_ALERT_THRESHOLD_PCT=0.08
